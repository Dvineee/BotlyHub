{
  "version": 2,
  "routes": [
    {
      "src": "/api/admin/add-admin",
      "dest": "/api/admin/add-admin.ts"
    },
    {
      "src": "/api/group-users/([^/]+)/seed",
      "dest": "/api/group-users/seed.ts?channelId=$1"
    },
    {
      "src": "/api/group-users/([^/]+)",
      "dest": "/api/group-users/[groupId].ts?groupId=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/tonconnect-manifest.json",
      "dest": "/api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
